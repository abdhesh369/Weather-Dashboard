# Required — MongoDB connection string
MONGO_URI=mongodb://localhost:27017/skycast

# Required — Secret used to sign JWT tokens
JWT_SECRET=your_super_secret_jwt_key_here

# Required — OpenWeatherMap API key (https://openweathermap.org/api)
WEATHER_API_KEY=your_openweathermap_api_key_here

# Optional — Port for the Express server (default: 5000)
PORT=5000

# Optional — Node environment: development | production
NODE_ENV=development

# Optional — Allowed CORS origin (default: http://localhost:5173)
ALLOWED_ORIGIN=http://localhost:5173
鼓
