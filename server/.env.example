# ═══════════════════════════════════════════════
#  SkyCast — Server Environment Variables
#  Copy this file to .env and fill in values
# ═══════════════════════════════════════════════

# ── Required ────────────────────────────────────
# MongoDB connection string (Atlas or local)
MONGO_URI=mongodb://localhost:27017/skycast

# Secret used to sign JWT access tokens (min 256-bit random string)
JWT_SECRET=your_super_secret_jwt_key_here_at_least_32_chars

# Secret used to sign JWT refresh tokens (use a different value from JWT_SECRET)
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here_different_from_jwt

# OpenWeatherMap API key (https://openweathermap.org/api)
WEATHER_API_KEY=your_openweathermap_api_key_here

# ── Optional ────────────────────────────────────
# Express server port (default: 5000)
PORT=5000

# Node environment: development | production
NODE_ENV=development

# Allowed CORS origin(s) — comma-separated for multiple
# In production set to your actual frontend domain
ALLOWED_ORIGIN=http://localhost:5173

# Redis URL for shared cache + rate limiting
# Leave empty to use in-memory fallback (single-instance only)
# Example: redis://localhost:6379
# Upstash:  rediss://:password@host:port
REDIS_URL=

# Sentry DSN for error tracking (leave empty to disable)
SENTRY_DSN=
